# Provider: fake (no infra, default) | ollama (local) | anthropic (API)
KG_PROVIDER=ollama

# --- Ollama (local) ---
OLLAMA_HOST=http://localhost:11434
KG_EXTRACT_MODEL=qwen2.5:7b
KG_REASON_MODEL=llama3.1:8b
KG_VERIFY_MODEL=qwen2.5:14b
KG_EMBED_MODEL=nomic-embed-text

# --- Retrieval / gating knobs ---
KG_TOP_K=20
KG_Q_THRESHOLD=3
KG_SALIENCE_FLOOR=0.35
KG_TOPICAL_REJECT=0.82
KG_HUB_QUARANTINE=10
KG_HUB_RADIUS=0.90
KG_MAX_SURFACED=5

# --- Anthropic (only when KG_PROVIDER=anthropic; embeddings fall back to Ollama) ---
# ANTHROPIC_API_KEY=sk-ant-...
# KG_ANTHROPIC_EXTRACT=claude-haiku-4-5-20251001
# KG_ANTHROPIC_REASON=claude-sonnet-4-6
# KG_ANTHROPIC_VERIFY=claude-sonnet-4-6
